# memU-server 配置文件示例
# 复制此文件为 .env 并填入你的配置

# ============================================
# LLM 配置（必需）
# ============================================

# 方式 1: 使用 OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEFAULT_LLM_MODEL=gpt-4o-mini

# 方式 2: 使用通义千问（推荐，便宜）
# OPENAI_API_KEY=sk-your-dashscope-api-key-here
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DEFAULT_LLM_MODEL=qwen-plus
# # DEFAULT_EMBED_MODEL=text-embedding-v3

# 方式 3: 使用硅基流动（OpenAI 兼容）
# OPENAI_API_KEY=sk-your-siliconflow-api-key-here
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# DEFAULT_LLM_MODEL=Qwen/Qwen3-8B
# DEFAULT_EMBED_MODEL=BAAI/bge-large-zh-v1.5

# 可选：手动覆盖 embedding 模型（不填时按 provider 自动选择）
# DEFAULT_EMBED_MODEL=text-embedding-3-small

# ============================================
# 数据库配置
# ============================================

# 数据库类型选择（必需）
# 可选值:
#   - sqlite: 轻量级文件数据库，无需安装，适合桌面应用和开发测试
#   - postgres: PostgreSQL 数据库，功能强大，支持 pgvector 向量搜索，适合生产环境
# DATABASE_PROVIDER=sqlite

# 方式 1: 使用 SQLite（推荐，无需额外安装）
# DATABASE_URL=sqlite:///./data/memu.db

# 方式 2: 使用 PostgreSQL（需要安装 pgvector 扩展）
# DATABASE_PROVIDER=postgres
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/memu

# 方式 3: 使用独立的数据库变量（仅 PostgreSQL）
DATABASE_PROVIDER=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=a1234567
DATABASE_NAME=memu

# ============================================
# 存储配置（可选）
# ============================================

# 对话文件存储路径
STORAGE_PATH=./data

# ============================================
# 说明
# ============================================

# 1. 复制此文件为 .env
# 2. 填入你的 API Key
# 3. 选择数据库配置方式（方式 1 或方式 2）
# 4. 运行: uv run fastapi dev
