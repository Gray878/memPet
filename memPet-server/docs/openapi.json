    "/chat": {
      "post": {
        "summary": "Chat",
        "description": "对话接口 - 支持记忆增强的 AI 对话\n\n请求参数:\n- message: 用户消息\n- history: 对话历史 (可选)\n- personality: 性格类型 (可选: friendly, energetic, professional, tsundere)\n- temperature: 温度参数 (可选, 默认 0.7)\n- max_tokens: 最大 token 数 (可选, 默认 2000)\n- retrieve_memories: 是否检索相关记忆 (可选, 默认 True)\n\n返回:\n- response: AI 回复\n- memories_used: 使用的记忆数量",
        "operationId": "chat_chat_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiEnvelope_ChatData_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
