      "get": {
        "summary": "Proactive Cooldown",
        "description": "获取冷却状态\n\n返回所有建议类型的冷却状态\n\n返回格式:\n{\n    \"status\": \"success\",\n    \"cooldowns\": {\n        \"fatigue_reminder\": {\n            \"cooldown_seconds\": 1800,\n            \"remaining_seconds\": 600,\n            \"can_trigger\": false,\n            \"last_triggered\": \"2024-02-15T10:00:00\"\n        }\n    }\n}",
        "operationId": "proactive_cooldown_proactive_cooldown_get",
