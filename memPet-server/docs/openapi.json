  "paths": {
    "/memorize": {
      "post": {
        "summary": "Memorize",
        "description": "存储记忆（支持对话和系统观察两种类型）\n\n对话记忆格式:\n{\n    \"user_id\": \"test_user\",\n    \"messages\": [\n        {\n            \"role\": \"user\",\n            \"content\": \"消息内容\"\n        },\n        {\n            \"role\": \"assistant\",\n            \"content\": \"回复内容\"\n        }\n    ]\n}\n\n系统观察格式:\n{\n    \"type\": \"system_observation\",\n    \"observation\": {\n        \"type\": \"app_switch\",\n        \"app\": \"VSCode\",\n        \"duration\": 3600,\n        \"timestamp\": \"2024-02-12T10:00:00\"\n    }\n}",
        "operationId": "memorize_memorize_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MemorizeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiEnvelope_MemorizeData_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/retrieve": {
      "post": {
        "summary": "Retrieve",
        "description": "检索相关记忆（支持对话和主动推理两种场景）\n\n对话场景格式:\n{\n    \"scenario\": \"conversation\",\n    \"user_id\": \"test_user\",\n    \"query\": \"查询文本\",\n    \"limit\": 3\n}\n\n主动推理场景格式:\n{\n    \"scenario\": \"proactive\",\n    \"context\": {\n        \"working_duration\": 7200,\n        \"active_app\": \"VSCode\",\n        \"fatigue_level\": \"Tired\",\n        \"is_late_night\": false,\n        \"idle_time\": 0\n    },\n    \"limit\": 5\n}",
        "operationId": "retrieve_retrieve_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RetrieveRequest"
              }
