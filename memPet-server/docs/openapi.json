                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/chat/stream": {
      "post": {
        "summary": "Chat Stream",
        "description": "流式对话接口 - 使用 SSE (Server-Sent Events) 返回打字机效果\n\n请求参数:\n- message: 用户消息（必需）\n- history: 对话历史（可选）\n- personality: 性格类型（可选: friendly, energetic, professional, tsundere）\n- temperature: 温度参数（可选, 默认 0.7）\n- max_tokens: 最大 token 数（可选, 默认 2000）\n- retrieve_memories: 是否检索相关记忆（可选, 默认 True）\n\nSSE 事件类型:\n- metadata: 元数据事件（包含 memories_used, memory_used）\n- chunk: 内容片段（包含 content 字段）\n- complete: 完成事件\n- error: 错误事件\n\n示例用法(JavaScript):\n    import { fetchEventSource } from '@microsoft/fetch-event-source';\n    await fetchEventSource('/chat/stream', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ message: '你好' }),\n        onmessage(ev) {\n            console.log(ev.event, ev.data);\n        },\n    });",
        "operationId": "chat_stream_chat_stream_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatStreamRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
