    "/memory-log": {
      "get": {
        "summary": "List Memory Log",
        "description": "查询记忆日志列表（用于记忆管理界面）\n\n参数:\n- limit: 返回数量限制 (1-200, 默认 50)\n- offset: 偏移量 (默认 0)\n- type: 记忆类型 (all, conversation, system_observation, 默认 all)\n- start_date: 开始日期 (可选)\n- end_date: 结束日期 (可选)\n\n返回格式:\n{\n    \"status\": \"success\",\n    \"data\": {\n        \"items\": [\n            {\n                \"id\": \"uuid\",\n                \"type\": \"conversation\",\n                \"content\": \"我今天写了500行代码\",\n                \"summary\": \"用户分享工作进展\",\n                \"created_at\": \"2024-02-27T18:30:00\",\n                \"metadata\": {}\n            }\n        ],\n        \"total\": 150,\n        \"has_more\": true\n    }\n}",
        "operationId": "list_memory_log_memory_log_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "title": "Limit"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "title": "Offset"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "all",
              "title": "Type"
            }
          },
          {
            "name": "start_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Start Date"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "End Date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiEnvelope_MemoriesListData_"
                }
