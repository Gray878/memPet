    "/proactive/analyze": {
      "post": {
        "summary": "Proactive Analyze",
        "description": "主动推理分析接口\n\n分析当前上下文，生成建议列表\n\n请求格式:\n{\n    \"context\": {\n        \"working_duration\": 7200,\n        \"active_app\": \"VSCode\",\n        \"fatigue_level\": \"Tired\",\n        \"is_late_night\": false,\n        \"idle_time\": 0,\n        \"is_work_hours\": true,\n        \"focus_level\": \"NormalFocus\"\n    }\n}\n\n返回格式:\n{\n    \"status\": \"success\",\n    \"suggestions\": [\n        {\n            \"type\": \"fatigue_reminder\",\n            \"priority\": \"high\",\n            \"message\": \"检测到疲劳\",\n            \"reason\": \"连续工作 2 小时\",\n            \"action\": \"建议休息 10 分钟\"\n        }\n    ]\n}",
        "operationId": "proactive_analyze_proactive_analyze_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProactiveAnalyzeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiEnvelope_ProactiveAnalyzeData_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/proactive/generate": {
      "post": {
        "summary": "Proactive Generate",
        "description": "生成主动推理消息\n\n根据建议和相关记忆，生成自然语言消息\n\n请求格式:\n{\n    \"suggestion\": {\n        \"type\": \"fatigue_reminder\",\n        \"priority\": \"high\",\n        \"message\": \"检测到疲劳\",\n        \"reason\": \"连续工作 2 小时\",\n        \"action\": \"建议休息 10 分钟\"\n    },\n    \"context\": {\n        \"working_duration\": 7200,\n        \"fatigue_level\": \"Tired\"\n    },\n    \"personality\": \"friendly\",\n    \"limit\": 3\n}\n\n返回格式:\n{\n    \"status\": \"success\",\n    \"message\": \"主人已经工作 2 小时了，要不要休息一下眼睛呀？\",\n    \"memories\": [...]\n}",
        "operationId": "proactive_generate_proactive_generate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProactiveGenerateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiEnvelope_ProactiveGenerateData_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/proactive/quick": {
      "post": {
        "summary": "Proactive Quick",
        "description": "快捷主动推理接口 - 一步完成分析和生成\n\n自动分析上下文，选择最高优先级的建议，并生成自然语言消息\n\n请求格式:\n{\n    \"context\": {\n        \"working_duration\": 7200,\n        \"active_app\": \"VSCode\",\n        \"fatigue_level\": \"Tired\",\n        \"is_late_night\": false,\n        \"idle_time\": 0,\n        \"is_work_hours\": true,\n        \"focus_level\": \"NormalFocus\"\n    },\n    \"personality\": \"friendly\",\n    \"limit\": 3\n}\n\n返回格式:\n{\n    \"status\": \"success\",\n    \"message\": \"主人已经工作 2 小时了，要不要休息一下眼睛呀？\",\n    \"suggestion\": {\n        \"type\": \"fatigue_reminder\",\n        \"priority\": \"high\",\n        \"message\": \"检测到疲劳\",\n        \"reason\": \"连续工作 2 小时\",\n        \"action\": \"建议休息 10 分钟\"\n    },\n    \"memories\": [...]\n}",
        "operationId": "proactive_quick_proactive_quick_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProactiveQuickRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
